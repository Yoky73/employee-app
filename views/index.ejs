<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employee Management System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="/style.css">
</head>

<body>

    <!-- Navbar -->

    <nav class="navbar navbar-expand-lg navbar-dark dashboard-header">
        <div class="container">

            <span class="navbar-brand fw-bold">
                <i class="bi bi-people-fill"></i>
                Employee Management System
            </span>

            <span class="text-white fw-bold">
                Welcome Admin 🚀 CI/CD Working
            </span>

        </div>
    </nav>

    <div class="container mt-4">

        <!-- Banner -->

        <div class="banner">

            <h1>
                💻 Human Resource Management System
            </h1>

            <p>
                👨🏻‍💻 Employee Management • 🌟 Department Tracking • 💵 Salary Analytics
            </p>

            <div class="mt-3">

                <span class="badge bg-light text-dark p-2">Node.js</span>
                <span class="badge bg-light text-dark p-2">Express.js</span>
                <span class="badge bg-light text-dark p-2">Docker</span>
                <span class="badge bg-light text-dark p-2">GitHub Actions</span>
                <span class="badge bg-light text-dark p-2">AWS EC2</span>

            </div>

        </div>

        <!-- Dashboard -->

        <div class="row mb-4">

            <div class="col-md-3 mb-3">
                <div class="card dashboard-card card-blue text-center">
                    <div class="card-body">
                        <h5>
                            <i class="bi bi-people-fill"></i>
                            Total Employees
                        </h5>
                        <h1><%= totalEmployees %></h1>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card dashboard-card card-green text-center">
                    <div class="card-body">
                        <h5>
                            <i class="bi bi-building"></i>
                            Departments
                        </h5>
                        <h1><%= totalDepartments %></h1>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card dashboard-card card-orange text-center">
                    <div class="card-body">
                        <h5>
                            <i class="bi bi-cash-stack"></i>
                            Avg Salary
                        </h5>
                        <h1>₹<%= averageSalary %></h1>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card dashboard-card card-purple text-center">
                    <div class="card-body">
                        <h5>
                            <i class="bi bi-trophy-fill"></i>
                            Highest Salary
                        </h5>
                        <h1>₹<%= highestSalary %></h1>
                    </div>
                </div>
            </div>

        </div>

        <!-- Demo Form -->

        <div class="card mb-4">

            <div class="card-body">

                <h3 class="mb-3">
                    <i class="bi bi-person-plus-fill"></i>
                    Add Employee (Demo Mode)
                </h3>

                <form>

                    <div class="mb-3">
                        <input type="text"
                               class="form-control"
                               placeholder="Employee Name"
                               disabled>
                    </div>

                    <div class="mb-3">
                        <input type="text"
                               class="form-control"
                               placeholder="Department"
                               disabled>
                    </div>

                    <div class="mb-3">
                        <input type="number"
                               class="form-control"
                               placeholder="Salary"
                               disabled>
                    </div>

                    <button type="button"
                            class="btn btn-primary"
                            disabled>
                        <i class="bi bi-lock-fill"></i>
                        Demo Mode
                    </button>

                </form>

            </div>

        </div>

        <!-- Employee Table -->

        <div class="card">

            <div class="card-body">

                <h3>
                    <i class="bi bi-table"></i>
                    Employee List
                </h3>

                <div class="mb-3 mt-3">
                    <input
                        type="text"
                        class="form-control"
                        placeholder="🔍 Search Employee (Coming Soon)"
                        disabled>
                </div>

                <table class="table table-hover">

                    <thead class="table-dark">

                        <tr>
                            <th>Name</th>
                            <th>Department</th>
                            <th>Salary</th>
                            <th>Action</th>
                        </tr>

                    </thead>

                    <tbody>

                        <% employees.forEach(employee => { %>

                        <tr>

                            <td>
                                <i class="bi bi-person-circle me-2"></i>
                                <%= employee.name %>
                            </td>

                            <td>
                                <span class="badge bg-primary">
                                    <%= employee.department %>
                                </span>
                            </td>

                            <td>
                                ₹ <%= employee.salary %>
                            </td>

                            <td>

                                <button
                                    class="btn btn-primary btn-sm"
                                    disabled>
                                    <i class="bi bi-pencil"></i>
                                </button>

                                <button
                                    class="btn btn-danger btn-sm"
                                    disabled>
                                    <i class="bi bi-trash"></i>
                                </button>

                            </td>

                        </tr>

                        <% }) %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</body>

</html>