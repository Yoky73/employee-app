<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employee Management System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="/style.css">
</head>

<body>

    <!-- Navbar -->

    <nav class="navbar navbar-expand-lg navbar-dark dashboard-header">
        <div class="container">

            <span class="navbar-brand fw-bold">
                <i class="bi bi-people-fill"></i>
                <h4>Employee Management System</h4>
            </span>

            <span class="text-white">
                <h4>Welcome Admin 👋</h4 >
            </span>

        </div>
    </nav>

    <div class="container mt-4">

        <!-- Banner -->

        <div class="banner">

            <h1>
                💻 Human Resource Management System
            </h1>

            <p>
                👨🏻‍💻 Employee Management • 🌟 Department Tracking • 💵Salary Analytics
            </p>

            <div class="mt-3">

                <span class="badge bg-light text-dark p-2">
                    Node.js
                </span>

                <span class="badge bg-light text-dark p-2">
                    Express.js
                </span>

                <span class="badge bg-light text-dark p-2">
                    MongoDB
                </span>

                <span class="badge bg-light text-dark p-2">
                    Docker
                </span>

                <span class="badge bg-light text-dark p-2">
                    AWS EC2
                </span>

            </div>

        </div>

        <!-- Dashboard Statistics -->

        <div class="row mb-4">

            <div class="col-md-3 mb-3">

                <div class="card dashboard-card card-blue text-center">

                    <div class="card-body">

                        <h5>
                            <i class="bi bi-people-fill"></i>
                            Total Employees
                        </h5>

                        <h1><%= totalEmployees %></h1>

                    </div>

                </div>

            </div>

            <div class="col-md-3 mb-3">

                <div class="card dashboard-card card-green text-center">

                    <div class="card-body">

                        <h5>
                            <i class="bi bi-building"></i>
                            Departments
                        </h5>

                        <h1><%= totalDepartments %></h1>

                    </div>

                </div>

            </div>

            <div class="col-md-3 mb-3">

                <div class="card dashboard-card card-orange text-center">

                    <div class="card-body">

                        <h5>
                            <i class="bi bi-cash-stack"></i>
                            Avg Salary
                        </h5>

                        <h1>₹<%= averageSalary %></h1>

                    </div>

                </div>

            </div>

            <div class="col-md-3 mb-3">

                <div class="card dashboard-card card-purple text-center">

                    <div class="card-body">

                        <h5>
                            <i class="bi bi-trophy-fill"></i>
                            Highest Salary
                        </h5>

                        <h1>₹<%= highestSalary %></h1>

                    </div>

                </div>

            </div>

        </div>

        <!-- Add Employee -->

        <div class="card mb-4">

            <div class="card-body">

                <h3 class="mb-3">
                    <i class="bi bi-person-plus-fill"></i>
                    Add Employee 𐦂𖨆𐀪𖠋
                </h3>

                <form action="/add" method="POST">

                    <div class="mb-3">

                        <input
                            type="text"
                            name="name"
                            class="form-control"
                            placeholder="Employee Name"
                            required>

                    </div>

                    <div class="mb-3">

                        <input
                            type="text"
                            name="department"
                            class="form-control"
                            placeholder="Department"
                            required>

                    </div>

                    <div class="mb-3">

                        <input
                            type="number"
                            name="salary"
                            class="form-control"
                            placeholder="Salary"
                            required>

                    </div>

                    <button class="btn btn-primary">

                        <i class="bi bi-plus-circle"></i>
                        Add Employee

                    </button>

                </form>

            </div>

        </div>

        <!-- Employee List -->

        <div class="card">

            <div class="card-body">

                <h3>
                    <i class="bi bi-table"></i>
                    Employee List
                </h3>

                <div class="mb-3 mt-3">

                    <input
                        type="text"
                        class="form-control"
                        placeholder="🔍 Search Employee (Coming Soon)">

                </div>

                <table class="table table-hover">

                    <thead class="table-dark">

                        <tr>

                            <th>Name</th>
                            <th>Department</th>
                            <th>Salary</th>
                            <th>Action</th>

                        </tr>

                    </thead>

                    <tbody>

                        <% employees.forEach(employee => { %>

                        <tr>

                            <td>

                                <i class="bi bi-person-circle me-2"></i>

                                <%= employee.name %>

                            </td>

                            <td>

                                <span class="badge bg-primary">

                                    <%= employee.department %>

                                </span>

                            </td>

                            <td>

                                ₹ <%= employee.salary %>

                            </td>

                            <td>

                                <a href="#"
                                   class="btn btn-primary btn-sm">

                                    <i class="bi bi-pencil"></i>

                                </a>

                                <a href="/delete/<%= employee._id %>"
                                   class="btn btn-danger btn-sm">

                                    <i class="bi bi-trash"></i>

                                </a>

                            </td>

                        </tr>

                        <% }) %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</body>

</html>